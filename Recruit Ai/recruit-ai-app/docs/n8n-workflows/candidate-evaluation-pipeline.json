    {
      "parameters": {
        "jsCode": "// Compute next available business day, skipping weekends & Indian public holidays\nconst items = $input.all();\n\nconst holidays2026 = [\n  '2026-01-26','2026-03-10','2026-04-03','2026-04-14',\n  '2026-05-01','2026-08-15','2026-08-19','2026-09-25',\n  '2026-10-02','2026-10-12','2026-11-02','2026-11-03',\n  '2026-11-19','2026-12-25'\n];\n\nfunction isBusinessDay(dt) {\n  if (dt.weekday === 6 || dt.weekday === 7) return false;\n  return !holidays2026.includes(dt.toFormat('yyyy-MM-dd'));\n}\n\nconst now = DateTime.now().setZone('Asia/Kolkata');\nlet candidate = now.plus({ days: 1 });\nlet attempts = 0;\nwhile (!isBusinessDay(candidate) && attempts < 10) {\n  candidate = candidate.plus({ days: 1 });\n  attempts++;\n}\n\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    proposed_interview_date: candidate.toFormat('yyyy-MM-dd'),\n    proposed_interview_time: '10:00 AM IST',\n    proposed_interview_day: candidate.toFormat('EEEE, MMMM dd, yyyy'),\n  }\n}));"
      },
      "id": "b1000001-0002-4000-8000-000000000002",
      "name": "Check Calendar",
      "type": "n8n-nodes-base.code",
